# === Node Environment ===
NODE_ENV=development

# === Application ===
PORT=3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# === Supabase ===
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=

# === Postgres (Supabase direct connection) ===
POSTGRES_URL=
POSTGRES_URL_NON_POOLING=
POSTGRES_PRISMA_URL=
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_HOST=
POSTGRES_DATABASE=

# === AI (Vercel AI Gateway) ===
# Get from: vercel.com → project → AI → Gateway
AI_GATEWAY_API_KEY=

# === Lead Sources ===
APOLLO_API_KEY=
GOOGLE_PLACES_API_KEY=

# === ElevenLabs (Voice Outreach) ===
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=pNInz6obpgDQGcFmaJgB
# === Rate Limiting (requests per window, override defaults)
# Auth endpoints: per IP, 15-min window
RATE_LIMIT_AUTH=10
# Discovery / scrape pipeline: per user, 1-hour window
RATE_LIMIT_DISCOVERY=10
# Scoring pipeline: per user, 1-min window
RATE_LIMIT_SCORING=60
# General API routes: per user (auth) or IP (anon), 1-min window
RATE_LIMIT_API_AUTHED=120
RATE_LIMIT_API_ANON=30

# === Sentry Error Monitoring ===
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# === Logging ===
LOG_LEVEL=info
